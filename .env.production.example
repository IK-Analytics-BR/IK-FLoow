# ========================================
# VARIÁVEIS DE AMBIENTE - PRODUÇÃO (AWS)
# ========================================
# Copie para .env e preencha com seus valores

# Flask
FLASK_ENV=production
SECRET_KEY=sua-chave-secreta-super-forte-aqui-mude-isso-123456789
DEBUG=False

# MySQL - AWS EC2
MYSQL_HOST=localhost
MYSQL_USER=supply_user
MYSQL_PASSWORD=SuaSenhaForte123!MudeIsso
MYSQL_DATABASE=supply_chain_system
MYSQL_PORT=3306

# Google Maps API (Geocodificação)
GOOGLE_MAPS_API_KEY=SuaChaveGoogleMapsAqui

# Here Maps API (Alternativa para geocodificação)
# Se não usar, deixar vazio
HERE_MAPS_API_KEY=

# Configurações de Aplicação
APP_NAME=Supply Chain System
APP_URL=http://seu-ip-ou-dominio.com
MAX_CONTENT_LENGTH=104857600  # 100MB em bytes

# Configurações de Segurança
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600  # 1 hora em segundos

# Configurações de Email (se usar)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=seu-email@gmail.com
# MAIL_PASSWORD=sua-senha-app

# Logs
LOG_LEVEL=INFO
LOG_FILE=/home/ubuntu/SupplyChainSystem/logs/app.log

# Timezone
TZ=America/Sao_Paulo

# Backup (se usar S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1
