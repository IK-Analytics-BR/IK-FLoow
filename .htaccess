# IK Flow - Supply Chain System
# Configuração para cPanel com Passenger WSGI

# Passenger WSGI Configuration
PassengerEnabled on
PassengerAppRoot /home/u312402671/public_html
PassengerPython /usr/bin/python3

# Directory Index
DirectoryIndex passenger_wsgi.py index.py app.py index.html

# Permissões de acesso
Order allow,deny
Allow from all

# Se não tiver Passenger, tentar CGI
<IfModule !mod_passenger.c>
    Options +ExecCGI
    AddHandler cgi-script .py
    
    <IfModule mod_rewrite.c>
        RewriteEngine On
        RewriteBase /
        
        RewriteCond %{REQUEST_FILENAME} !-f
        RewriteCond %{REQUEST_FILENAME} !-d
        RewriteRule ^(.*)$ passenger_wsgi.py/$1 [QSA,L]
    </IfModule>
</IfModule>
